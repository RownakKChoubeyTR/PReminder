{
    "name": "preminder",
    "version": "0.1.0",
    "private": true,
    "description": "GitHub PR Review Reminder SPA — Track open PRs and send review reminders via Teams, email, and desktop notifications.",
    "author": "",
    "license": "MIT",
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=9.0.0"
    },
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint . && prettier --check .",
        "lint:fix": "eslint --fix . && prettier --write .",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:api": "vitest run src/tests/api",
        "test:components": "vitest run src/tests/components",
        "test:hooks": "vitest run src/tests/hooks",
        "test:lib": "vitest run src/tests/lib",
        "test:pages": "vitest run src/tests/pages",
        "test:context": "vitest run src/tests/context",
        "test:middleware": "vitest run src/tests/middleware.test.ts",
        "db:generate": "prisma generate",
        "db:migrate": "node scripts/prisma-cli.mjs migrate dev",
        "db:migrate:deploy": "node scripts/prisma-cli.mjs migrate deploy",
        "db:migrate:staging": "node scripts/prisma-cli.mjs --env-file .env.staging migrate deploy",
        "db:migrate:production": "node scripts/prisma-cli.mjs --env-file .env.production migrate deploy",
        "db:studio": "node scripts/prisma-cli.mjs studio",
        "db:seed": "node scripts/prisma-cli.mjs db seed",
        "db:reset": "node scripts/prisma-cli.mjs migrate reset",
        "docker:dev": "docker-compose -f docker/docker-compose.yml up -d",
        "docker:build": "docker build -t preminder:latest -f docker/Dockerfile .",
        "docker:down": "docker-compose -f docker/docker-compose.yml down",
        "prepare": "prisma generate"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    },
    "dependencies": {
        "@prisma/client": "^6.0.0",
        "@radix-ui/react-avatar": "^1.1.0",
        "@radix-ui/react-checkbox": "^1.1.0",
        "@radix-ui/react-dialog": "^1.1.0",
        "@radix-ui/react-dropdown-menu": "^2.1.0",
        "@radix-ui/react-label": "^2.1.0",
        "@radix-ui/react-select": "^2.1.0",
        "@radix-ui/react-separator": "^1.1.0",
        "@radix-ui/react-slot": "^1.1.0",
        "@radix-ui/react-switch": "^1.1.0",
        "@radix-ui/react-tabs": "^1.1.0",
        "@radix-ui/react-toast": "^1.2.0",
        "@radix-ui/react-toggle-group": "^1.1.0",
        "@radix-ui/react-tooltip": "^1.1.0",
        "@splinetool/react-spline": "^4.1.0",
        "@splinetool/runtime": "^1.12.61",
        "@t3-oss/env-nextjs": "^0.11.0",
        "@tailwindcss/postcss": "^4.2.1",
        "@tanstack/react-query": "^5.60.0",
        "clsx": "^2.1.0",
        "framer-motion": "^12.34.3",
        "lucide-react": "^0.460.0",
        "next": "^15.1.0",
        "next-auth": "^5.0.0-beta.25",
        "postcss": "^8.5.6",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.1",
        "zod": "^3.23.0",
        "zustand": "^5.0.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.2.0",
        "@testing-library/jest-dom": "^6.6.0",
        "@testing-library/react": "^16.1.0",
        "@testing-library/user-event": "^14.5.0",
        "@types/node": "^22.10.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.3.0",
        "@vitest/coverage-v8": "^2.1.0",
        "eslint": "^9.15.0",
        "eslint-config-next": "^15.1.0",
        "jsdom": "^28.1.0",
        "prettier": "^3.4.0",
        "prettier-plugin-organize-imports": "^4.1.0",
        "prisma": "^6.0.0",
        "sass": "^1.82.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "vitest": "^2.1.0"
    }
}
